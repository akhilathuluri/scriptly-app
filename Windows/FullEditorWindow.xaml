<Window x:Class="Scriptly.Windows.FullEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scriptly — Full Editor"
        Width="720" Height="540"
        MinWidth="480" MinHeight="360"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.CacheMode>
        <BitmapCache EnableClearType="True" SnapsToDevicePixels="True"/>
    </Window.CacheMode>

    <!-- Outermost border provides the visual chrome; resize is handled via WndProc -->
    <Border x:Name="RootBorder"
            Background="#16161E"
            CornerRadius="12"
            Opacity="0"
            RenderTransformOrigin="0.5,0.5">

        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="ScaleT" ScaleX="0.97" ScaleY="0.97"/>
            </TransformGroup>
        </Border.RenderTransform>

        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#000000" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Padding="18,13,14,11" MouseDown="TitleBar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleIcon" FontSize="16" Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TitleText"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="#C8C8E8" VerticalAlignment="Center"/>
                        <TextBlock Text=" — Full View" FontSize="14"
                                   Foreground="#5A5A7A" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="1" Content="✕" Click="CloseButton_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#5A5A7A" FontSize="14" Cursor="Hand"
                            Width="28" Height="28" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Separator -->
            <Border Grid.Row="0" Height="1" Background="#1E1E34" VerticalAlignment="Bottom"/>

            <!-- Main text area -->
            <Border Grid.Row="1" Background="#111118" Margin="12,8,12,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TextBox x:Name="ResultTextBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#DCDCF4"
                             FontFamily="Cascadia Code, Consolas, monospace"
                             FontSize="13.5"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             VerticalScrollBarVisibility="Disabled"
                             HorizontalScrollBarVisibility="Disabled"
                             SelectionBrush="#7C6AF755"
                             CaretBrush="#7C6AF7"
                             Padding="14,12"
                             TextChanged="ResultTextBox_TextChanged"/>
                </ScrollViewer>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="14,10,14,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Word / char count -->
                    <TextBlock x:Name="WordCountLabel"
                               FontSize="11" Foreground="#40405A"
                               VerticalAlignment="Center"/>

                    <!-- Close -->
                    <Button Grid.Column="1" Content="Close"
                            Click="CloseButton_Click"
                            FontSize="13" Padding="14,7" BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#1E1E34" CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2A2A4A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground>
                            <SolidColorBrush Color="#8888B0"/>
                        </Button.Foreground>
                    </Button>

                    <!-- Copy -->
                    <Button Grid.Column="3" Content="Copy"
                            Click="CopyButton_Click"
                            FontSize="13" FontWeight="Medium"
                            Padding="18,7" BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#222234" CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2E2E48"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground>
                            <SolidColorBrush Color="#B0B0D0"/>
                        </Button.Foreground>
                    </Button>

                    <!-- Replace -->
                    <Button Grid.Column="5" Content="Replace"
                            Click="ReplaceButton_Click"
                            FontSize="13" FontWeight="Medium"
                            Padding="18,7" BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#5A4AF7" CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#6B5AF8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground>
                            <SolidColorBrush Color="White"/>
                        </Button.Foreground>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
