<Window x:Class="Scriptly.Windows.AskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ask AI"
        Width="420"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.CacheMode>
        <BitmapCache EnableClearType="True" SnapsToDevicePixels="True"/>
    </Window.CacheMode>

    <Border x:Name="RootBorder"
            Background="#16161E"
            CornerRadius="14"
            Opacity="0"
            RenderTransformOrigin="0.5,0.5">

        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="ScaleT" ScaleX="0.92" ScaleY="0.92"/>
                <TranslateTransform x:Name="TranslateT" Y="8"/>
            </TransformGroup>
        </Border.RenderTransform>

        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Color="#000000" Opacity="0.65"/>
        </Border.Effect>

        <Grid Margin="16,14,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="💬" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Ask AI" FontSize="14" FontWeight="SemiBold"
                               Foreground="#C8C8E8" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Click="CloseButton_Click"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#5A5A7A" FontSize="13" Cursor="Hand"
                        Padding="4,0" Height="24" Width="24" VerticalAlignment="Center"/>
            </Grid>

            <!-- Selected text context preview -->
            <Border Grid.Row="1" x:Name="ContextBorder"
                    Background="#1A1A28" CornerRadius="8"
                    Padding="12,9" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="SELECTED TEXT" FontSize="10" Foreground="#4A4A6A"
                               FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="ContextPreview"
                               FontSize="12" Foreground="#7070A0"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="52" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Prompt input area -->
            <Border Grid.Row="2" Background="#1E1E2E" CornerRadius="10"
                    Padding="14,12" Margin="0,0,0,12">
                <Grid>
                    <TextBox x:Name="PromptBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#E0E0F0"
                             CaretBrush="#7C6AF7"
                             SelectionBrush="#7C6AF755"
                             FontSize="14"
                             TextWrapping="Wrap"
                             AcceptsReturn="False"
                             MinHeight="28"
                             MaxHeight="120"
                             VerticalScrollBarVisibility="Disabled"
                             KeyDown="PromptBox_KeyDown"
                             TextChanged="PromptBox_TextChanged"/>
                    <!-- Placeholder overlay -->
                    <TextBlock x:Name="Placeholder"
                               Text="Ask anything about the selected text…"
                               Foreground="#383858"
                               FontSize="14"
                               IsHitTestVisible="False"
                               VerticalAlignment="Top"/>
                </Grid>
            </Border>

            <!-- Footer: hint + send button -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="↵ send  •  esc cancel" FontSize="10.5"
                           Foreground="#3A3A5A" VerticalAlignment="Center"/>

                <Button Grid.Column="1" x:Name="AskButton"
                        Content="Ask →"
                        Click="AskButton_Click"
                        IsEnabled="False"
                        Foreground="White"
                        FontSize="13" FontWeight="Medium"
                        Padding="18,8"
                        Background="#5A4AF7"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#6B5AF8"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#7C6AF9"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

        </Grid>
    </Border>
</Window>
