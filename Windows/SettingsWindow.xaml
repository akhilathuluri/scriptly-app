<Window x:Class="Scriptly.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scriptly Settings"
        Width="540"
        Height="640"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.CacheMode>
        <BitmapCache EnableClearType="True" SnapsToDevicePixels="True"/>
    </Window.CacheMode>

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9090B0"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="BorderBrush" Value="#2A2A42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#7C6AF7"/>
            <Setter Property="SelectionBrush" Value="#7C6AF755"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A48"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#34345A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="BorderBrush" Value="#2A2A42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ComboItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Grid.Column="0"
                                                      Margin="10,0,6,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>

                                    <Path Grid.Column="1"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Right"
                                          Fill="#9C9CC0"
                                          Data="M 0 0 L 4 4 L 8 0 Z"/>

                                    <ToggleButton Grid.ColumnSpan="2"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  ClickMode="Press"/>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Margin="0,4,0,0"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        Background="#1A1A28"
                                        BorderBrush="#2A2A42"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <ScrollViewer x:Name="DropDownScrollViewer"
                                                  MaxHeight="220"
                                                  SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#3A3A58"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#7C6AF7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7C6AF7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#5A4AF7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#6B5AF8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#222234"/>
            <Setter Property="Foreground" Value="#B0B0D0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E2E48"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PasswordStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="BorderBrush" Value="#2A2A42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#7C6AF7"/>
            <Setter Property="SelectionBrush" Value="#7C6AF755"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Background="#16161E" CornerRadius="14"
            Opacity="0"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="ScaleT" ScaleX="0.96" ScaleY="0.96"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Color="#000000" Opacity="0.65"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Padding="20,16,16,0" MouseDown="TitleBar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚙" FontSize="16" Foreground="#7C6AF7" Margin="0,0,8,0"/>
                        <TextBlock Text="Settings" FontSize="16" FontWeight="SemiBold" Foreground="#E0E0F0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="✕" Click="CloseButton_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#5A5A7A" FontSize="14" Cursor="Hand"
                            Width="28" Height="28"/>
                </Grid>
            </Border>

            <!-- Scrollable content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,8,20,0">
                <StackPanel>

                    <!-- ── AI Provider ── -->
                    <TextBlock Text="AI PROVIDER" Style="{StaticResource SectionHeader}"/>

                    <TextBlock Text="Provider" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="ProviderCombo" Style="{StaticResource ComboStyle}"
                              SelectionChanged="ProviderCombo_SelectionChanged"
                              Margin="0,0,0,12">
                        <ComboBoxItem Content="OpenRouter" Tag="OpenRouter"/>
                        <ComboBoxItem Content="Groq" Tag="Groq"/>
                    </ComboBox>

                    <!-- OpenRouter settings -->
                    <StackPanel x:Name="OpenRouterPanel">
                        <TextBlock Text="OpenRouter API Key" Style="{StaticResource LabelStyle}"/>
                        <PasswordBox x:Name="OpenRouterKeyBox" Style="{StaticResource PasswordStyle}"
                                 Margin="0,0,0,10"
                                 ToolTip="Your OpenRouter API key from openrouter.ai"/>

                        <TextBlock Text="Model (e.g. openai/gpt-4o-mini)" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="OpenRouterModelBox" Style="{StaticResource InputStyle}"
                                 Margin="0,0,0,12"
                                 ToolTip="Full model identifier from OpenRouter"/>
                    </StackPanel>

                    <!-- Groq settings -->
                    <StackPanel x:Name="GroqPanel" Visibility="Collapsed">
                        <TextBlock Text="Groq API Key" Style="{StaticResource LabelStyle}"/>
                        <PasswordBox x:Name="GroqKeyBox" Style="{StaticResource PasswordStyle}"
                                 Margin="0,0,0,10"
                                 ToolTip="Your Groq API key from console.groq.com"/>

                        <TextBlock Text="Model (e.g. llama-3.3-70b-versatile)" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="GroqModelBox" Style="{StaticResource InputStyle}"
                                 Margin="0,0,0,12"
                                 ToolTip="Groq model name"/>
                    </StackPanel>

                    <Border Background="#1A1A28" CornerRadius="8" Padding="12,10" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="API keys are encrypted with Windows DPAPI."
                                       Foreground="#8080A8" FontSize="12" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Rotate Keys"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="RotateKeys_Click" FontSize="11" Padding="10,5"/>
                        </Grid>
                    </Border>

                    <!-- ── Hotkey ── -->
                    <TextBlock Text="KEYBOARD SHORTCUT" Style="{StaticResource SectionHeader}"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Modifiers (e.g. Ctrl+Shift)" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="HotkeyModifiers" Style="{StaticResource InputStyle}"
                                     ToolTip="Ctrl, Shift, Alt, Win - combine with +"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Key (e.g. Space)" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="HotkeyKey" Style="{StaticResource InputStyle}"
                                     ToolTip="Any keyboard key name"/>
                        </StackPanel>
                    </Grid>

                    <!-- ── General ── -->
                    <TextBlock Text="GENERAL" Style="{StaticResource SectionHeader}"/>
                    <Border Background="#1A1A28" CornerRadius="8" Padding="12,10" Margin="0,0,0,12">
                        <CheckBox x:Name="StartWithWindowsCheck"
                                  Content="Start Scriptly automatically when Windows starts"
                                  Foreground="#B0B0C8" FontSize="13" Cursor="Hand"/>
                    </Border>

                    <!-- ── Custom Actions ── -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="CUSTOM ACTIONS" Style="{StaticResource SectionHeader}"
                                   Margin="0,16,0,0" VerticalAlignment="Bottom"/>
                        <Button Grid.Column="1" Content="+ New Action"
                                Style="{StaticResource SecondaryButton}"
                                Click="NewAction_Click"
                                FontSize="12" Padding="10,5"
                                VerticalAlignment="Bottom" Margin="0,16,0,0"/>
                    </Grid>

                    <ItemsControl x:Name="CustomActionsList" Margin="0,0,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1A2A" CornerRadius="8"
                                        Margin="0,0,0,6" Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Icon}" FontSize="18"
                                                   VerticalAlignment="Center" Width="30"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                                            <TextBlock Text="{Binding Name}" FontSize="13"
                                                       FontWeight="SemiBold" Foreground="#D0D0F0"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="#6C6C8A" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Edit"
                                                Tag="{Binding}"
                                                Click="EditAction_Click"
                                                Style="{StaticResource SecondaryButton}"
                                                FontSize="11" Padding="8,4" Margin="4,0"/>
                                        <Button Grid.Column="3" Content="✕"
                                                Tag="{Binding}"
                                                Click="DeleteAction_Click"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="#FF5050" FontSize="13"
                                                Cursor="Hand" Padding="4,0" Width="24"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ── About ── -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                Margin="0,12,0,8">
                        <TextBlock x:Name="VersionLabel" FontSize="11" Foreground="#38385A"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" · " FontSize="11" Foreground="#2E2E50"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="ReleasesButton"
                                Content="View releases"
                                Click="ReleasesButton_Click"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#48488A" FontSize="11"
                                Cursor="Hand" Padding="0" VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="{TemplateBinding Foreground}"
                                               FontSize="{TemplateBinding FontSize}"
                                               x:Name="Lbl"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Lbl" Property="TextDecorations" Value="Underline"/>
                                            <Setter TargetName="Lbl" Property="Foreground" Value="#6060B8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer buttons -->
            <Border Grid.Row="2" Padding="20,12,20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusLabel" FontSize="12" Foreground="#6C9C6C"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Cancel" Style="{StaticResource SecondaryButton}"
                            Click="CancelButton_Click"/>
                    <Button Grid.Column="3" Content="Save" Style="{StaticResource PrimaryButton}"
                            Click="SaveButton_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
