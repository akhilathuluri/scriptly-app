<Window x:Class="Scriptly.Windows.ActionPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Scriptly.Windows"
        Title="Scriptly Actions"
        Width="320"
        Height="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        MaxHeight="480"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>
        <!-- Smooth easing -->
        <CubicEase x:Key="SmoothEase" EasingMode="EaseOut"/>

        <!-- Action item style -->
        <Style x:Key="ActionItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Margin="4,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A3A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D3D5C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search box style -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="CaretBrush" Value="#7C6AF7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Scrollbar hide style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="#444466" CornerRadius="2"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- GPU layer -->
    <Window.CacheMode>
        <BitmapCache EnableClearType="True" SnapsToDevicePixels="True"/>
    </Window.CacheMode>

    <Border x:Name="RootBorder"
            Background="#16161E"
            CornerRadius="14"
            Opacity="0"
            RenderTransformOrigin="0.5,0.5">

        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="ScaleT" ScaleX="0.92" ScaleY="0.92"/>
                <TranslateTransform x:Name="TranslateT" Y="8"/>
            </TransformGroup>
        </Border.RenderTransform>

        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Color="#000000" Opacity="0.65"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="16,14,16,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Scriptly" FontSize="13" FontWeight="SemiBold"
                               Foreground="#6C6C8A" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ProviderLabel" Grid.Column="1"
                               FontSize="11" Foreground="#4A4A6A"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Search bar -->
            <Border Grid.Row="1" Margin="10,10,10,4"
                    Background="#1E1E2E" CornerRadius="10" Height="40">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔍" FontSize="13" Margin="12,0,0,0"
                               VerticalAlignment="Center" Foreground="#5A5A7A"/>
                    <TextBox x:Name="SearchBox"
                             Grid.Column="1"
                             Style="{StaticResource SearchBoxStyle}"
                             Height="40"
                             TextChanged="SearchBox_TextChanged"
                             KeyDown="SearchBox_KeyDown"/>
                </Grid>
            </Border>

            <!-- Actions list -->
            <ListBox x:Name="ActionsList"
                     Grid.Row="2"
                     Background="Transparent"
                     BorderThickness="0"
                     Margin="6,4,6,4"
                     MaxHeight="300"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ItemContainerStyle="{StaticResource ActionItemStyle}"
                     KeyDown="ActionsList_KeyDown"
                     MouseDoubleClick="ActionsList_MouseDoubleClick"
                     MouseLeftButtonUp="ActionsList_MouseLeftButtonUp"
                     SelectionChanged="ActionsList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Icon}" FontSize="15"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0">
                                <TextBlock Text="{Binding Name}" FontSize="13.5"
                                           FontWeight="Medium" Foreground="#E8E8F0"/>
                                <TextBlock Text="{Binding Description}" FontSize="11"
                                           Foreground="#6C6C8A" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Border Grid.Column="2"
                                    Background="#222234" CornerRadius="4"
                                    Padding="6,2" Margin="4,0,2,0"
                                    Visibility="{Binding Shortcut, Converter={local:StringToVisibilityConverter}}">
                                <TextBlock Text="{Binding Shortcut}" FontSize="11"
                                           Foreground="#7C6AF7" FontFamily="Consolas" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Footer hint -->
            <Border Grid.Row="3" Padding="14,6,14,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="↑↓ navigate" FontSize="10.5" Foreground="#3A3A5A"/>
                    <TextBlock Text="  •  " FontSize="10.5" Foreground="#3A3A5A"/>
                    <TextBlock Text="↵ select" FontSize="10.5" Foreground="#3A3A5A"/>
                    <TextBlock Text="  •  " FontSize="10.5" Foreground="#3A3A5A"/>
                    <TextBlock Text="esc close" FontSize="10.5" Foreground="#3A3A5A"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
