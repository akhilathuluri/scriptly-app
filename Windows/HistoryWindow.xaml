<Window x:Class="Scriptly.Windows.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scriptly History"
        Width="480" Height="560"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.CacheMode>
        <BitmapCache EnableClearType="True" SnapsToDevicePixels="True"/>
    </Window.CacheMode>

    <Border x:Name="RootBorder"
            Background="#16161E"
            CornerRadius="14"
            Opacity="0"
            RenderTransformOrigin="0.5,0">

        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="ScaleT" ScaleX="0.94" ScaleY="0.94"/>
                <TranslateTransform x:Name="TranslateT" Y="-10"/>
            </TransformGroup>
        </Border.RenderTransform>

        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Color="#000000" Opacity="0.65"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Padding="18,14,14,12" MouseDown="TitleBar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📋" FontSize="15" Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="History" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#E0E0F0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="CountLabel" FontSize="12" Foreground="#505080"
                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Clear all -->
                    <Button Grid.Column="1" x:Name="ClearAllButton"
                            Content="Clear all"
                            Click="ClearAll_Click"
                            Visibility="Collapsed"
                            FontSize="11" BorderThickness="0" Cursor="Hand" Padding="10,4">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#1E1E34" CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2A2A48"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground>
                            <SolidColorBrush Color="#7070AA"/>
                        </Button.Foreground>
                    </Button>

                    <!-- Close -->
                    <Button Grid.Column="3" Content="✕" Click="CloseButton_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#5A5A7A" FontSize="14" Cursor="Hand"
                            Width="28" Height="28"/>
                </Grid>
            </Border>

            <!-- Separator -->
            <Border Grid.Row="0" Height="1" Background="#1E1E34" VerticalAlignment="Bottom"/>

            <!-- Empty state -->
            <StackPanel Grid.Row="1" x:Name="EmptyPanel" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="📭" FontSize="38" HorizontalAlignment="Center"
                           Margin="0,0,0,14"/>
                <TextBlock Text="No history yet" FontSize="14" Foreground="#506080"
                           HorizontalAlignment="Center" FontWeight="Medium"/>
                <TextBlock Text="Processed results will appear here" FontSize="12"
                           Foreground="#383858" HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Entries list -->
            <ScrollViewer Grid.Row="1" x:Name="EntriesScroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="14,10,14,4" Visibility="Collapsed">
                <ItemsControl x:Name="EntriesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1A1A28" CornerRadius="10"
                                    Margin="0,0,0,8" Padding="13,11">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header: icon + name + time + copy button -->
                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ActionIcon}"
                                                       FontSize="13" Margin="0,0,6,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ActionName}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#9090C8"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding RelativeTime}"
                                                       FontSize="11" Foreground="#404070"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                            <Button Tag="{Binding}"
                                                    Content="Copy"
                                                    Click="CopyEntry_Click"
                                                    FontSize="11" Cursor="Hand"
                                                    BorderThickness="0" Padding="8,3">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd"
                                                                Background="#20203A"
                                                                CornerRadius="5"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#2C2C50"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <Button.Foreground>
                                                    <SolidColorBrush Color="#7070C0"/>
                                                </Button.Foreground>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Input text snippet -->
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding SelectedTextPreview}"
                                               FontSize="11" Foreground="#404060"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,5"/>

                                    <!-- Result snippet -->
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding ResultPreview}"
                                               FontSize="12.5" Foreground="#B8B8E0"
                                               TextWrapping="Wrap" MaxHeight="58"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Footer hint -->
            <Border Grid.Row="2" Padding="18,8,18,14">
                <TextBlock x:Name="FooterHint"
                           FontSize="11" Foreground="#383858"
                           HorizontalAlignment="Center"
                           Text="Click Copy on any entry to copy the result"/>
            </Border>
        </Grid>
    </Border>
</Window>
