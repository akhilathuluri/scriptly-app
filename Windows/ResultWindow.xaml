<Window x:Class="Scriptly.Windows.ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scriptly Result"
        Width="380"
        SizeToContent="Height"
        MaxHeight="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.CacheMode>
        <BitmapCache EnableClearType="True" SnapsToDevicePixels="True"/>
    </Window.CacheMode>

    <Border x:Name="RootBorder"
            Background="#16161E"
            CornerRadius="14"
            Opacity="0"
            RenderTransformOrigin="0.5,0">

        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="ScaleT" ScaleX="0.94" ScaleY="0.94"/>
                <TranslateTransform x:Name="TranslateT" Y="-10"/>
            </TransformGroup>
        </Border.RenderTransform>

        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Color="#000000" Opacity="0.65"/>
        </Border.Effect>

        <Grid Margin="16,14,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title row -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="ActionIcon" FontSize="16" Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="ActionTitle" FontSize="14" FontWeight="SemiBold"
                               Foreground="#C8C8E8" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" x:Name="CloseButton"
                        Content="✕" Click="CloseButton_Click"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#5A5A7A" FontSize="13" Cursor="Hand"
                        Padding="4,0" Height="24" Width="24"
                        VerticalAlignment="Center"/>
            </Grid>

            <!-- Thinking indicator / result area -->
            <Border Grid.Row="1" x:Name="ThinkingPanel"
                    Background="#1A1A28" CornerRadius="10" Padding="14,12"
                    Margin="0,0,0,10" Visibility="Visible">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ThinkingDot1" Text="●" FontSize="10"
                               Foreground="#7C6AF7" Margin="0,0,4,0">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="DotT1"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock x:Name="ThinkingDot2" Text="●" FontSize="10"
                               Foreground="#7C6AF7" Margin="0,0,4,0">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="DotT2"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock x:Name="ThinkingDot3" Text="●" FontSize="10"
                               Foreground="#7C6AF7">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="DotT3"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock Text=" Thinking..." FontSize="13"
                               Foreground="#7C6AF7" Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Result text -->
            <Border Grid.Row="2" x:Name="ResultPanel"
                    Background="#1A1A28" CornerRadius="10" Padding="14,12"
                    Margin="0,0,0,12" Visibility="Collapsed"
                    MinHeight="60" MaxHeight="280">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <TextBox x:Name="ResultText"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#E0E0F0"
                             FontSize="13.5"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             SelectionBrush="#7C6AF755"
                             CaretBrush="#7C6AF7"
                             Cursor="IBeam"/>
                </ScrollViewer>
            </Border>

            <!-- Error panel -->
            <Border Grid.Row="2" x:Name="ErrorPanel"
                    Background="#2A1A1A" CornerRadius="10" Padding="14,12"
                    Margin="0,0,0,12" Visibility="Collapsed">
                <TextBlock x:Name="ErrorText"
                           Foreground="#FF7070"
                           FontSize="13"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Diff panel — inline highlighted diff of original vs. result -->
            <Border Grid.Row="2" x:Name="DiffPanel"
                    Background="#1A1A28" CornerRadius="10" Padding="12,10"
                    Margin="0,0,0,12" Visibility="Collapsed"
                    MinHeight="60" MaxHeight="280">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Diff legend -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,0,8">
                        <Border Background="#2A1818" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                            <TextBlock FontSize="10.5" Foreground="#FF6B6B">
                                <Run Text="─"/>
                                <Run Text=" removed" Foreground="#884444"/>
                            </TextBlock>
                        </Border>
                        <Border Background="#182A1E" CornerRadius="4" Padding="6,2">
                            <TextBlock FontSize="10.5" Foreground="#7EC88B">
                                <Run Text="+"/>
                                <Run Text=" added" Foreground="#447855"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <!-- Diff content -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <RichTextBox x:Name="DiffText"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontSize="13.5"
                                     IsReadOnly="True"
                                     Padding="2,0,0,0"
                                     SelectionBrush="#7C6AF755"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Action buttons -->
            <Grid Grid.Row="3" x:Name="ButtonPanel" Visibility="Collapsed">

                <!-- Left: compact icon-only utility buttons -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Diff view toggle: only visible for text-transform actions -->
                    <Button x:Name="DiffToggleButton"
                            Content="Changes"
                            Click="DiffToggleButton_Click"
                            ToolTip="Show changes from original"
                            Visibility="Collapsed"
                            FontSize="11" Height="32" Padding="10,0"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,6,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#1E1E38" CornerRadius="8"
                                        Height="32" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2A2A4A"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#34345A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground>
                            <SolidColorBrush Color="#7C6AF7"/>
                        </Button.Foreground>
                    </Button>

                    <!-- Expand to full editor -->
                    <Button x:Name="ExpandButton"
                            Content="⤢"
                            Click="ExpandButton_Click"
                            ToolTip="Open in full editor"
                            Visibility="Collapsed"
                            FontSize="14" Width="32" Height="32" Padding="0"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,6,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#222234" CornerRadius="8"
                                        Width="32" Height="32">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2E2E48"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#383858"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground>
                            <SolidColorBrush Color="#7C6AF7"/>
                        </Button.Foreground>
                    </Button>

                    <!-- Regenerate / try again -->
                    <Button x:Name="RegenerateButton"
                            Content="↺"
                            Click="RegenerateButton_Click"
                            ToolTip="Try again"
                            FontSize="16" Width="32" Height="32" Padding="0"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#222234" CornerRadius="8"
                                        Width="32" Height="32">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2E2E48"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#383858"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground>
                            <SolidColorBrush Color="#9090B8"/>
                        </Button.Foreground>
                    </Button>
                </StackPanel>

                <!-- Right: primary action buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CopyButton"
                            Content="Copy"
                            Click="CopyButton_Click"
                            FontSize="13" FontWeight="Medium"
                            Padding="18,8" BorderThickness="0"
                            Cursor="Hand" Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#222234" CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2E2E48"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#383858"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground>
                            <SolidColorBrush Color="#B0B0D0"/>
                        </Button.Foreground>
                    </Button>

                    <Button x:Name="ReplaceButton"
                            Content="Replace"
                            Click="ReplaceButton_Click"
                            FontSize="13" FontWeight="Medium"
                            Padding="18,8" BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#5A4AF7" CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#6B5AF8"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#7C6AF9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground>
                            <SolidColorBrush Color="White"/>
                        </Button.Foreground>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
